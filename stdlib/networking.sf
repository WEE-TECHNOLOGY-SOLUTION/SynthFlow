}

// ===== URL Parsing =====

// Parse URL into components
fn url_parse(url: string) -> map {
    return __builtin_url_parse(url)
}

// Build URL from components
fn url_build(components: map) -> string {
    let result = ""
    if (components.protocol != "") {
        result = result + components.protocol + "://"
    }
    if (components.username != "") {
        result = result + components.username
        if (components.password != "") {
            result = result + ":" + components.password
        }
        result = result + "@"
    }
    result = result + components.host
    if (components.port != 0 && components.port != 80 && components.port != 443) {
        result = result + ":" + str(components.port)
    }
    result = result + components.path
    if (components.query != "") {
        result = result + "?" + components.query
    }
    if (components.fragment != "") {
        result = result + "#" + components.fragment
    }
    return result
}

// Encode URL component
fn url_encode_component(text: string) -> string {
    return __builtin_url_encode(text)
}

// Decode URL component
fn url_decode_component(text: string) -> string {
    return __builtin_url_decode(text)
}

// ===== IP Address Utilities =====

// Check if valid IPv4
fn is_ipv4(addr: string) -> bool {
    return regex.test("^(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$", addr)
}

// Check if valid IPv6
fn is_ipv6(addr: string) -> bool {
    // Simple check
    return contains(addr, ":") && !contains(addr, ".")
}

// Convert IP to integer
fn ip_to_int(ip: string) -> int {
    return __builtin_ip_to_int(ip)
}

// Convert integer to IP
fn int_to_ip(num: int) -> string {
    return __builtin_int_to_ip(num)
}

// Check if IP is in CIDR range
fn ip_in_range(ip: string, cidr: string) -> bool {
    return __builtin_ip_in_cidr(ip, cidr)
}

// ===== Helper Functions =====

fn contains(text: string, search: string) -> bool {
    return indexOf(text, search, 0) >= 0
}

fn indexOf(text: string, search: string, start: int) -> int {
    // Placeholder - would call builtin
    return -1
}
