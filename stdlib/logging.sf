fn replace(text: string, search: string, replacement: string) -> string {
    return text  // Placeholder
}

fn padRight(text: string, length: int) -> string {
    let result = text
    while (len(result) < length) {
        result = result + " "
    }
    return result
}

fn join(arr: array, delimiter: string) -> string {
    let result = ""
    for (let i = 0; i < len(arr); i = i + 1) {
        if (i > 0) { result = result + delimiter }
        result = result + str(arr[i])
    }
    return result
}

