// ===== Filesystem Operations =====

// List directory contents
fn listDir(path: string) -> array {
    // Returns array of {name, isDir, size, modified}
    print("[SYSADMIN] Listing: " + path)
    return []
}

// List directory with pattern matching
fn listDirGlob(path: string, pattern: string) -> array {
    let allFiles = listDir(path)
    let results = []
    
    for (let i = 0; i < len(allFiles); i = i + 1) {
        if (matchGlob(allFiles[i].name, pattern)) {
            results = append(results, allFiles[i])
        }
    }
    
    return results
}

// Walk directory recursively
fn walkDir(path: string, callback: fn) -> void {
    let entries = listDir(path)
    
    for (let i = 0; i < len(entries); i = i + 1) {
        let entry = entries[i]
        let fullPath = joinPath(path, entry.name)
        
        callback(fullPath, entry)
        
        if (entry.isDir) {
            walkDir(fullPath, callback)
        }
    }
}

// Find files matching pattern
fn findFiles(path: string, pattern: string) -> array {
    let results = []
    
    fn collector(filePath: string, entry: map) {
        if (!entry.isDir && matchGlob(entry.name, pattern)) {
            results = append(results, filePath)
        }
    }
    
    walkDir(path, collector)
    return results
}

// Create directory
fn mkdir(path: string, recursive: bool) -> bool {
    print("[SYSADMIN] Creating directory: " + path)
    return true
}

// Remove file or directory
fn remove(path: string, recursive: bool) -> bool {
    print("[SYSADMIN] Removing: " + path)
    return true
}

// Move/rename file or directory
fn move(source: string, dest: string) -> bool {
    print("[SYSADMIN] Moving: " + source + " -> " + dest)
    return true
}

// Copy file
fn copy(source: string, dest: string) -> bool {
    print("[SYSADMIN] Copying: " + source + " -> " + dest)
    return true
}

// Copy directory recursively
fn copyDir(source: string, dest: string) -> bool {
    mkdir(dest, true)
    
    let entries = listDir(source)
    for (let i = 0; i < len(entries); i = i + 1) {
        let entry = entries[i]
        let srcPath = joinPath(source, entry.name)
        let dstPath = joinPath(dest, entry.name)
        
        if (entry.isDir) {
            copyDir(srcPath, dstPath)
        } else {
            copy(srcPath, dstPath)
        }
    }
    
    return true
}

