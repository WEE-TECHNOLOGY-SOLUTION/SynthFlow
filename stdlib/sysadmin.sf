// ===== Path Operations =====

// Join path components
fn joinPath(base: string, path: string) -> string {
    if (endsWith(base, "/") || endsWith(base, "\\")) {
        return base + path
    }
    return base + "/" + path
}

// Get directory name from path
fn dirName(path: string) -> string {
    let lastSlash = lastIndexOf(path, "/")
    let lastBackslash = lastIndexOf(path, "\\")
    let idx = max(lastSlash, lastBackslash)
    
    if (idx > 0) {
        return substr(path, 0, idx)
    }
    return "."
}

// Get base name from path
fn baseName(path: string) -> string {
    let lastSlash = lastIndexOf(path, "/")
    let lastBackslash = lastIndexOf(path, "\\")
    let idx = max(lastSlash, lastBackslash)
    
    if (idx >= 0) {
        return substr(path, idx + 1, len(path) - idx - 1)
    }
    return path
}

// Get file extension
fn extName(path: string) -> string {
    let base = baseName(path)
    let dotIdx = lastIndexOf(base, ".")
    
    if (dotIdx > 0) {
        return substr(base, dotIdx, len(base) - dotIdx)
    }
    return ""
}

