// ===== Service Management =====

// Start system service
fn startService(serviceName: string) -> bool {
    return exec("systemctl start " + serviceName).success
}

// Stop system service
fn stopService(serviceName: string) -> bool {
    return exec("systemctl stop " + serviceName).success
}

// Restart system service
fn restartService(serviceName: string) -> bool {
    return exec("systemctl restart " + serviceName).success
}

// Check service status
fn getServiceStatus(serviceName: string) -> map {
    let result = exec("systemctl status " + serviceName)
    return {
        "running": result.exitCode == 0,
        "enabled": false,
        "output": result.stdout
    }
}

// Enable service at boot
fn enableService(serviceName: string) -> bool {
    return exec("systemctl enable " + serviceName).success
}

// Disable service at boot
fn disableService(serviceName: string) -> bool {
    return exec("systemctl disable " + serviceName).success
}

