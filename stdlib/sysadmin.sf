// Get local IP address
fn getLocalIP() -> string {
    let interfaces = getNetworkInterfaces()
    for (let i = 0; i < len(interfaces); i = i + 1) {
        let iface = interfaces[i]
        if (iface.ip != "127.0.0.1" && len(iface.ip) > 0) {
            return iface.ip
        }
    }
    return "127.0.0.1"
}

