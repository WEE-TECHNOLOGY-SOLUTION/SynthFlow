// ===== Archive Operations =====

// Create tar archive
fn createTar(outputPath: string, inputPaths: array) -> bool {
    let args = ["-cf", outputPath]
    for (let i = 0; i < len(inputPaths); i = i + 1) {
        args = append(args, inputPaths[i])
    }
    return execArgs("tar", args).success
}

// Extract tar archive
fn extractTar(archivePath: string, destPath: string) -> bool {
    return execArgs("tar", ["-xf", archivePath, "-C", destPath]).success
}

// Create zip archive
fn createZip(outputPath: string, inputPaths: array) -> bool {
    let args = ["-r", outputPath]
    for (let i = 0; i < len(inputPaths); i = i + 1) {
        args = append(args, inputPaths[i])
    }
    return execArgs("zip", args).success
}

// Extract zip archive
fn extractZip(archivePath: string, destPath: string) -> bool {
    return execArgs("unzip", [archivePath, "-d", destPath]).success
}

// ===== Utility Functions =====

fn matchGlob(text: string, pattern: string) -> bool {
    // Simple glob matcher (* and ?)
    // Placeholder implementation
    if (pattern == "*") { return true }
    if (pattern == text) { return true }
    
    // Check for wildcard at end
    if (endsWith(pattern, "*")) {
        let prefix = substr(pattern, 0, len(pattern) - 1)
        return startsWith(text, prefix)
    }
    
    // Check for wildcard at start
    if (startsWith(pattern, "*")) {
        let suffix = substr(pattern, 1, len(pattern) - 1)
        return endsWith(text, suffix)
    }
    
    return false
}

fn endsWith(text: string, suffix: string) -> bool {
    if (len(suffix) > len(text)) { return false }
    return substr(text, len(text) - len(suffix), len(suffix)) == suffix
}

fn startsWith(text: string, prefix: string) -> bool {
    if (len(prefix) > len(text)) { return false }
    return substr(text, 0, len(prefix)) == prefix
}

fn substr(text: string, start: int, length: int) -> string {
    // Placeholder - would use built-in substring
    return text
}

fn lastIndexOf(text: string, search: string) -> int {
    // Placeholder - find last occurrence
    return -1
}

fn max(a: int, b: int) -> int {
    if (a > b) { return a }
    return b
}
