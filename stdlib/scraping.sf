fn contains(text: string, search: string) -> bool {
    return indexOf(text, search, 0) >= 0
}

fn stripQuotes(text: string) -> string {
    if (len(text) >= 2) {
        let first = charAt(text, 0)
        let last = charAt(text, len(text) - 1)
        if ((first == "\"" && last == "\"") || (first == "'" && last == "'")) {
            return substr(text, 1, len(text) - 2)
        }
    }
    return text
}

